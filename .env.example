# ─────────────────────────────────────────────────────────────────────────────
# Explorion — Environment Variables
# Copy this file to .env and fill in your own keys.
# All services below have a free tier — no credit card required.
# ─────────────────────────────────────────────────────────────────────────────


# ── Pinecone (vector database for session memory) ─────────────────────────────
# Sign up : https://app.pinecone.io
# Go to   : API Keys → Create API Key
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1


# ── Tavily (web search for research agent) ────────────────────────────────────
# Sign up : https://app.tavily.com
# Go to   : Dashboard → API Keys → Copy key
# Free tier: 1,000 searches / month
TAVILY_API_KEY=your_tavily_api_key_here


# ── LangSmith (pipeline tracing and monitoring) ───────────────────────────────
# Sign up : https://smith.langchain.com
# Go to   : Settings → API Keys → Create API Key
# Free tier: unlimited traces on personal plan
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGCHAIN_PROJECT=Explorion


# ── Ollama URL (optional — auto-detected, only set if you need to override) ───
# Leave commented out unless Ollama is running on a non-standard host/port.
# Running locally (no Docker) : http://localhost:11434/v1
# Running in Docker            : auto-detected as http://host.docker.internal:11434/v1
# OLLAMA_BASE_URL=http://localhost:11434/v1


# ── Google Gemini (optional — only needed if you switch manager to Gemini) ────
# Sign up : https://aistudio.google.com
# Go to   : Get API Key → Create API Key in new project
# Free tier: 1,500 requests / day on gemini-2.0-flash
# GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_MANAGER_MODEL=gemini-2.0-flash
